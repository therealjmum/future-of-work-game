import { useEffect, useRef, useState } from "react";

export default function OGGenerator() {
  const canvasRef = useRef(null);
  const [ready, setReady] = useState(false);

  useEffect(() => {
    const canvas = canvasRef.current;
    const ctx = canvas.getContext("2d");
    const W = 1200, H = 630;

    ctx.fillStyle = "#1A1917";
    ctx.fillRect(0, 0, W, H);

    const glow = ctx.createRadialGradient(900, 60, 0, 900, 60, 560);
    glow.addColorStop(0,   "rgba(204,85,0,0.38)");
    glow.addColorStop(0.4, "rgba(204,85,0,0.10)");
    glow.addColorStop(1,   "rgba(26,25,23,0)");
    ctx.fillStyle = glow;
    ctx.fillRect(0, 0, W, H);

    const bot = ctx.createLinearGradient(0, 430, 0, H);
    bot.addColorStop(0, "rgba(0,0,0,0)");
    bot.addColorStop(1, "rgba(0,0,0,0.4)");
    ctx.fillStyle = bot;
    ctx.fillRect(0, 0, W, H);

    ctx.font = "600 22px Arial";
    ctx.fillStyle = "#CC5500";
    ctx.fillText("FUTURE OF WORK  ·  2030", 80, 148);

    ctx.font = "900 104px Arial";
    ctx.fillStyle = "#FFFFFF";
    ctx.fillText("Imagine it\u2019s 2030.", 80, 282);

    ctx.fillStyle = "#3A3936";
    ctx.fillText("What do you believe?", 80, 398);

    ctx.font = "300 27px Arial";
    ctx.fillStyle = "rgba(255,255,255,0.38)";
    ctx.fillText("An interactive card game about work in the age of AI", 80, 480);

    ctx.fillStyle = "#CC5500";
    ctx.beginPath();
    ctx.roundRect(80, 540, 110, 5, 3);
    ctx.fill();

    ["#CC5500","#7C3AED","#1D4ED8","#0F766E","#D97706","#9D174D","#374151"].forEach((col, i) => {
      ctx.fillStyle = col;
      ctx.beginPath();
      ctx.arc(80 + i * 30, 578, 8, 0, Math.PI * 2);
      ctx.fill();
    });

    setReady(true);
  }, []);

  function download() {
    const canvas = canvasRef.current;
    const a = document.createElement("a");
    a.href = canvas.toDataURL("image/png");
    a.download = "og-image.png";
    a.click();
  }

  return (
    <div style={{fontFamily:"Inter,Arial,sans-serif",background:"#FAF9F7",minHeight:"100vh",padding:"40px 24px",display:"flex",flexDirection:"column",alignItems:"center",gap:28}}>
      <div style={{textAlign:"center"}}>
        <div style={{fontSize:"0.68em",letterSpacing:"3px",textTransform:"uppercase",color:"#CC5500",fontWeight:600,marginBottom:8}}>Step 1</div>
        <h1 style={{fontSize:"1.9em",fontWeight:900,color:"#1A1917",letterSpacing:"-1px",marginBottom:6}}>Download your OG image</h1>
        <p style={{color:"#8A8784",fontWeight:300,fontSize:"0.95em"}}>Then upload <code>og-image.png</code> to your GitHub repo root</p>
      </div>

      <canvas ref={canvasRef} width={1200} height={630}
        style={{width:"100%",maxWidth:700,borderRadius:12,boxShadow:"0 8px 40px rgba(0,0,0,0.15)",border:"1px solid #E8E4DC"}} />

      {ready && (
        <button onClick={download}
          style={{background:"#CC5500",color:"white",border:"none",padding:"17px 44px",borderRadius:"50px",fontSize:"1em",fontWeight:700,cursor:"pointer",fontFamily:"inherit",boxShadow:"0 6px 20px rgba(204,85,0,0.35)"}}>
          ⬇ Download og-image.png
        </button>
      )}

      <div style={{background:"white",border:"1px solid #E8E4DC",borderRadius:14,padding:"20px 28px",maxWidth:520,width:"100%"}}>
        <div style={{fontSize:"0.68em",letterSpacing:"2px",textTransform:"uppercase",color:"#CC5500",fontWeight:600,marginBottom:10}}>Steps</div>
        <ol style={{color:"#4A4845",fontSize:"0.88em",lineHeight:2,paddingLeft:18,margin:0}}>
          <li>Click <strong>Download og-image.png</strong> above</li>
          <li>Go to your GitHub repo and delete the existing <code>og-image.png</code></li>
          <li>Upload the new file you just downloaded</li>
          <li>Wait 1 min then re-test on opengraph.xyz ✓</li>
        </ol>
      </div>
    </div>
  );
}
